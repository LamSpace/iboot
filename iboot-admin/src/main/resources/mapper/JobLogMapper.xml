<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.iboot.admin.infrastructure.persistence.mapper.JobLogMapper">

    <resultMap id="JobLogResultMap" type="com.iboot.admin.infrastructure.persistence.po.JobLogPO">
        <id property="id" column="id"/>
        <result property="jobId" column="job_id"/>
        <result property="jobName" column="job_name"/>
        <result property="jobGroup" column="job_group"/>
        <result property="invokeTarget" column="invoke_target"/>
        <result property="jobMessage" column="job_message"/>
        <result property="status" column="status"/>
        <result property="exceptionInfo" column="exception_info"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="costTime" column="cost_time"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectJobLogVo">
        SELECT id,
               job_id,
               job_name,
               job_group,
               invoke_target,
               job_message,
               status,
               exception_info,
               start_time,
               end_time,
               cost_time,
               create_time
        FROM sys_job_log
    </sql>

    <insert id="insert" parameterType="com.iboot.admin.infrastructure.persistence.po.JobLogPO" useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO sys_job_log (job_id, job_name, job_group, invoke_target, job_message, status, exception_info,
                                 start_time, end_time, cost_time)
        VALUES (#{jobId}, #{jobName}, #{jobGroup}, #{invokeTarget}, #{jobMessage}, #{status}, #{exceptionInfo},
                #{startTime}, #{endTime}, #{costTime})
    </insert>

    <select id="selectById" resultMap="JobLogResultMap">
        <include refid="selectJobLogVo"/>
        WHERE id = #{id}
    </select>

    <select id="selectByJobId" resultMap="JobLogResultMap">
        <include refid="selectJobLogVo"/>
        WHERE job_id = #{jobId}
        ORDER BY create_time DESC
    </select>

    <select id="selectPage" resultMap="JobLogResultMap">
        <include refid="selectJobLogVo"/>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="selectPageByCondition" resultMap="JobLogResultMap">
        <include refid="selectJobLogVo"/>
        <where>
            <if test="jobId != null">
                AND job_id = #{jobId}
            </if>
            <if test="jobName != null and jobName != ''">
                AND job_name LIKE CONCAT('%', #{jobName}, '%')
            </if>
            <if test="jobGroup != null and jobGroup != ''">
                AND job_group = #{jobGroup}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="startTime != null">
                AND create_time &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*)
        FROM sys_job_log
    </select>

    <select id="countByCondition" resultType="long">
        SELECT COUNT(*) FROM sys_job_log
        <where>
            <if test="jobId != null">
                AND job_id = #{jobId}
            </if>
            <if test="jobName != null and jobName != ''">
                AND job_name LIKE CONCAT('%', #{jobName}, '%')
            </if>
            <if test="jobGroup != null and jobGroup != ''">
                AND job_group = #{jobGroup}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
            <if test="startTime != null">
                AND create_time &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
    </select>

    <delete id="deleteBeforeDate">
        DELETE
        FROM sys_job_log
        WHERE create_time &lt; #{beforeDate}
    </delete>

    <delete id="deleteByJobId">
        DELETE
        FROM sys_job_log
        WHERE job_id = #{jobId}
    </delete>

</mapper>
